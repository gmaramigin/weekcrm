a:5:{s:5:"title";s:64:"Spiro updates email attachments to send files instead of links";s:16:"text-format-info";a:3:{s:10:"text-final";s:444:"<p>Spiro overhauled attachments in outbound email so recipients receive files, not links. In-app, attachments are indicated with a paperclip and can be previewed (for images), opened in a new tab, or downloaded. The update is consistent across desktop and mobile.</p>
<p>Learn more here: <a href="https://support.spiro.ai/article/648-spiro-release-january-2026">https://support.spiro.ai/article/648-spiro-release-january-2026</a></p>
";s:9:"text-flow";a:2:{i:0;s:260:"Spiro overhauled attachments in outbound email so recipients receive files, not links. In-app, attachments are indicated with a paperclip and can be previewed (for images), opened in a new tab, or downloaded. The update is consistent across desktop and mobile.";i:1;s:80:"Learn more here: https://support.spiro.ai/article/648-spiro-release-january-2026";}s:4:"meta";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}}s:7:"summary";s:122:"Spiro overhauled attachments in outbound email so recipients receive files, not links. | Read fresh CRM news at WeekCRM";s:14:"comments-count";i:0;s:9:"tags-data";a:2:{s:5:"ctree";a:3:{i:0;a:3:{s:8:"visible?";b:1;s:4:"name";s:3:"CRM";s:4:"href";s:33:"http://weekcrm.com/blog/tags/crm/";}i:1;a:3:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:45:"http://weekcrm.com/blog/tags/product-updates/";}i:2;a:3:{s:8:"visible?";b:1;s:4:"name";s:5:"Spiro";s:4:"href";s:35:"http://weekcrm.com/blog/tags/spiro/";}}s:20:"all-resnames-uploads";a:0:{}}}