a:5:{s:5:"title";s:45:"Salesmate adds run-time variables for quotes";s:16:"text-format-info";a:3:{s:10:"text-final";s:455:"<p>Salesmate now supports run-time variables in quote templates, enabling automatic insertion of CRM data into a quote without manual editing.</p>
<p>Where to find it: Quotes → Templates → Variables.</p>
<p>Examples: customer/company name, deal owner/value, validity dates, custom fields.</p>
<p>Learn more here: <a href="https://www.salesmate.io/blog/january-2026-release-notes/">https://www.salesmate.io/blog/january-2026-release-notes/</a></p>
";s:9:"text-flow";a:4:{i:0;s:139:"Salesmate now supports run-time variables in quote templates, enabling automatic insertion of CRM data into a quote without manual editing.";i:1;s:53:"Where to find it: Quotes → Templates → Variables.";i:2;s:81:"Examples: customer/company name, deal owner/value, validity dates, custom fields.";i:3;s:74:"Learn more here: https://www.salesmate.io/blog/january-2026-release-notes/";}s:4:"meta";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}}s:7:"summary";s:175:"Salesmate now supports run-time variables in quote templates, enabling automatic insertion of CRM data into a quote without manual editing. | Read fresh CRM news on WeekCRM";s:14:"comments-count";i:0;s:9:"tags-data";a:2:{s:5:"ctree";a:3:{i:0;a:3:{s:8:"visible?";b:1;s:4:"name";s:3:"CRM";s:4:"href";s:34:"https://weekcrm.com/blog/tags/crm/";}i:1;a:3:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:46:"https://weekcrm.com/blog/tags/product-updates/";}i:2;a:3:{s:8:"visible?";b:1;s:4:"name";s:9:"salesmate";s:4:"href";s:40:"https://weekcrm.com/blog/tags/salesmate/";}}s:20:"all-resnames-uploads";a:0:{}}}