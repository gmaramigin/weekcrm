a:5:{s:5:"title";s:66:"Salesmate adds variable review to prevent blank fields in quotes";s:16:"text-format-info";a:3:{s:10:"text-final";s:433:"<p>Salesmate introduced a pre-send/pre-download review that surfaces variable values and highlights missing data.</p>
<p>Where to find it: Quotes → Preview/Send → Variable Review.</p>
<p>Impact: fewer quotes sent with blanks (names, dates, or other required fields).</p>
<p>Learn more here: <a href="https://www.salesmate.io/blog/january-2026-release-notes/">https://www.salesmate.io/blog/january-2026-release-notes/</a></p>
";s:9:"text-flow";a:4:{i:0;s:110:"Salesmate introduced a pre-send/pre-download review that surfaces variable values and highlights missing data.";i:1;s:62:"Where to find it: Quotes → Preview/Send → Variable Review.";i:2;s:79:"Impact: fewer quotes sent with blanks (names, dates, or other required fields).";i:3;s:74:"Learn more here: https://www.salesmate.io/blog/january-2026-release-notes/";}s:4:"meta";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}}s:7:"summary";s:145:"Salesmate introduced a pre-send/pre-download review that surfaces variable values and highlights missing data. | Read fresh CRM news on WeekCRM";s:14:"comments-count";i:0;s:9:"tags-data";a:2:{s:5:"ctree";a:3:{i:0;a:3:{s:8:"visible?";b:1;s:4:"name";s:3:"CRM";s:4:"href";s:33:"http://weekcrm.com/blog/tags/crm/";}i:1;a:3:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:45:"http://weekcrm.com/blog/tags/product-updates/";}i:2;a:3:{s:8:"visible?";b:1;s:4:"name";s:9:"salesmate";s:4:"href";s:39:"http://weekcrm.com/blog/tags/salesmate/";}}s:20:"all-resnames-uploads";a:0:{}}}