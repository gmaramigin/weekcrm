a:5:{s:5:"title";s:64:"Follow Up Boss brings voice prompts to Smart Messages on mobile";s:16:"text-format-info";a:3:{s:10:"text-final";s:1115:"<p>Follow Up Boss updated its mobile app to let users create Smart Messages using voice input. Instead of typing a custom prompt, users can speak it and generate an AI draft for a text or email.</p>
<h3>What’s new</h3>
<ul>
<li>Voice-to-prompt input for Smart Messages on mobile</li>
<li>Generates AI drafts for texts and emails</li>
<li>Uses the full lead timeline and activity for context</li>
<li>Works on iOS and Android</li>
<li>Drafts are reviewable/editable before sending</li>
</ul>
<h3>How it works</h3>
<ol start="1">
<li>Start a text or email on mobile</li>
<li>Choose the custom prompt Smart Message option</li>
<li>Tap the microphone</li>
<li>Speak your prompt</li>
<li>Review/edit the generated message, then send</li>
</ol>
<h3>Rollout</h3>
<p>The feature is rolling out via mobile app updates over the next week (auto-update or update manually).</p>
<p>Learn more here: <a href="https://updates.followupboss.com/en/use-your-voice-to-create-custom-smart-messages-on-mobile">https://updates.followupboss.com/en/use-your-voice-to-create-custom-smart-messages-on-mobile</a></p>
";s:9:"text-flow";a:8:{i:0;s:191:"Follow Up Boss updated its mobile app to let users create Smart Messages using voice input. Instead of typing a custom prompt, users can speak it and generate an AI draft for a text or email.";i:1;a:2:{i:0;s:2:"h2";i:1;s:12:"What’s new";}i:2;a:2:{i:0;s:9:"AeOldList";i:1;a:5:{i:0;a:5:{s:5:"class";s:7:"ul-item";s:7:"content";s:52:"- Voice-to-prompt input for Smart Messages on mobile";s:10:"class-data";a:2:{i:0;s:52:"- Voice-to-prompt input for Smart Messages on mobile";i:1;s:52:"- Voice-to-prompt input for Smart Messages on mobile";}s:6:"result";s:0:"";s:5:"depth";i:0;}i:1;a:5:{s:5:"class";s:7:"ul-item";s:7:"content";s:42:"- Generates AI drafts for texts and emails";s:10:"class-data";a:2:{i:0;s:42:"- Generates AI drafts for texts and emails";i:1;s:42:"- Generates AI drafts for texts and emails";}s:6:"result";s:0:"";s:5:"depth";i:0;}i:2;a:5:{s:5:"class";s:7:"ul-item";s:7:"content";s:54:"- Uses the full lead timeline and activity for context";s:10:"class-data";a:2:{i:0;s:54:"- Uses the full lead timeline and activity for context";i:1;s:54:"- Uses the full lead timeline and activity for context";}s:6:"result";s:0:"";s:5:"depth";i:0;}i:3;a:5:{s:5:"class";s:7:"ul-item";s:7:"content";s:26:"- Works on iOS and Android";s:10:"class-data";a:2:{i:0;s:26:"- Works on iOS and Android";i:1;s:26:"- Works on iOS and Android";}s:6:"result";s:0:"";s:5:"depth";i:0;}i:4;a:5:{s:5:"class";s:7:"ul-item";s:7:"content";s:47:"- Drafts are reviewable/editable before sending";s:10:"class-data";a:2:{i:0;s:47:"- Drafts are reviewable/editable before sending";i:1;s:47:"- Drafts are reviewable/editable before sending";}s:6:"result";s:0:"";s:5:"depth";i:0;}}}i:3;a:2:{i:0;s:2:"h2";i:1;s:12:"How it works";}i:4;a:2:{i:0;s:9:"AeOldList";i:1;a:5:{i:0;a:5:{s:5:"class";s:7:"ol-item";s:7:"content";s:34:"1. Start a text or email on mobile";s:10:"class-data";a:2:{i:0;s:34:"1. Start a text or email on mobile";i:1;s:1:"1";}s:6:"result";s:0:"";s:5:"depth";i:0;}i:1;a:5:{s:5:"class"