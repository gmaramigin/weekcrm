a:5:{s:5:"title";s:44:"Scoro adds export/import workflow for roles";s:16:"text-format-info";a:3:{s:10:"text-final";s:545:"<p>Scoro introduced a bulk-management workflow for roles:</p>
<p>Export the full roles list as CSV or XLS from Settings → Sales and finance → Roles</p>
<p>Edit values (e. g., pricing) in the file</p>
<p>Import the file to apply updates, while leaving unchanged roles intact</p>
<p>The export includes a role initials column (not visible in the UI yet, but available in export).</p>
<p>Learn more: <a href="https://www.scoro.com/blog/scoro-version-update-26-1/">https://www.scoro.com/blog/scoro-version-update-26-1/</a></p>
";s:9:"text-flow";a:6:{i:0;s:54:"Scoro introduced a bulk-management workflow for roles:";i:1;s:86:"Export the full roles list as CSV or XLS from Settings → Sales and finance → Roles";i:2;s:39:"Edit values (e.g., pricing) in the file";i:3;s:70:"Import the file to apply updates, while leaving unchanged roles intact";i:4;s:96:"The export includes a role initials column (not visible in the UI yet, but available in export).";i:5;s:65:"Learn more: https://www.scoro.com/blog/scoro-version-update-26-1/";}s:4:"meta";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}}s:7:"summary";s:88:"Scoro introduced a bulk-management workflow for roles | Read fresh CRM news on WeekCRM";s:14:"comments-count";i:0;s:9:"tags-data";a:2:{s:5:"ctree";a:3:{i:0;a:3:{s:8:"visible?";b:1;s:4:"name";s:3:"CRM";s:4:"href";s:33:"http://weekcrm.com/blog/tags/crm/";}i:1;a:3:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:45:"http://weekcrm.com/blog/tags/product-updates/";}i:2;a:3:{s:8:"visible?";b:1;s:4:"name";s:5:"scoro";s:4:"href";s:35:"http://weekcrm.com/blog/tags/scoro/";}}s:20:"all-resnames-uploads";a:0:{}}}