a:5:{s:5:"title";s:54:"Scoro adds booking notes and improves booking context";s:16:"text-format-info";a:3:{s:10:"text-final";s:451:"<p>Scoro introduced booking notes to explain why a user/role is booked and to reduce follow-up questions. Notes can be added when creating or modifying bookings at portfolio or project level.</p>
<p>Also included:</p>
<p>hover over user name → role</p>
<p>hover over booking → project name</p>
<p>Learn more here: <a href="https://www.scoro.com/blog/scoro-version-update-26-1/">https://www.scoro.com/blog/scoro-version-update-26-1/</a></p>
";s:9:"text-flow";a:5:{i:0;s:188:"Scoro introduced booking notes to explain why a user/role is booked and to reduce follow-up questions. Notes can be added when creating or modifying bookings at portfolio or project level.";i:1;s:14:"Also included:";i:2;s:29:"hover over user name → role";i:3;s:35:"hover over booking → project name";i:4;s:70:"Learn more here: https://www.scoro.com/blog/scoro-version-update-26-1/";}s:4:"meta";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}}s:7:"summary";s:228:"Scoro introduced booking notes to explain why a user/role is booked and to reduce follow-up questions. Notes can be added when creating or modifying bookings at portfolio or project level. | Read fresh CRM news on WeekCRM";s:14:"comments-count";i:0;s:9:"tags-data";a:2:{s:5:"ctree";a:3:{i:0;a:3:{s:8:"visible?";b:1;s:4:"name";s:3:"CRM";s:4:"href";s:33:"http://weekcrm.com/blog/tags/crm/";}i:1;a:3:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:45:"http://weekcrm.com/blog/tags/product-updates/";}i:2;a:3:{s:8:"visible?";b:1;s:4:"name";s:5:"scoro";s:4:"href";s:35:"http://weekcrm.com/blog/tags/scoro/";}}s:20:"all-resnames-uploads";a:0:{}}}