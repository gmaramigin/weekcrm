a:5:{s:5:"title";s:59:"Day.ai adds Slack delivery for scheduled assistant actions";s:16:"text-format-info";a:3:{s:10:"text-final";s:577:"<p>Day.ai now lets assistant schedules deliver outputs to any Slack channel, expanding beyond inbox-only notifications. The change is aimed at making scheduled reports and alerts visible to entire teams without manual forwarding. Configuration is done via the assistant notification setting (‘notify via’).</p>
<p>Learn more here: <a href="https://www.day.ai/resources/your-assistant-posts-to-slack-channels-cleaner-tables-floating-meeting-controls">https://www.day.ai/resources/your-assistant-posts-to-slack-channels-cleaner-tables-floating-meeting-controls</a></p>
";s:9:"text-flow";a:2:{i:0;s:303:"Day.ai now lets assistant schedules deliver outputs to any Slack channel, expanding beyond inbox-only notifications. The change is aimed at making scheduled reports and alerts visible to entire teams without manual forwarding. Configuration is done via the assistant notification setting ('notify via').";i:1;s:125:"Learn more here: https://www.day.ai/resources/your-assistant-posts-to-slack-channels-cleaner-tables-floating-meeting-controls";}s:4:"meta";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}}s:7:"summary";s:151:"Day.ai now lets assistant schedules deliver outputs to any Slack channel, expanding beyond inbox-only notifications. | Read fresh CRM news at WeekCRM";s:14:"comments-count";i:0;s:9:"tags-data";a:2:{s:5:"ctree";a:3:{i:0;a:3:{s:8:"visible?";b:1;s:4:"name";s:3:"CRM";s:4:"href";s:33:"http://weekcrm.com/blog/tags/crm/";}i:1;a:3:{s:8:"visible?";b:1;s:4:"name";s:6:"day.ai";s:4:"href";s:36:"http://weekcrm.com/blog/tags/day-ai/";}i:2;a:3:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:45:"http://weekcrm.com/blog/tags/product-updates/";}}s:20:"all-resnames-uploads";a:0:{}}}