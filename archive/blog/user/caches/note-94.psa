a:5:{s:5:"title";s:47:"Spiro adds per-report fiscal year configuration";s:16:"text-format-info";a:3:{s:10:"text-final";s:420:"<p>Reports can now be configured to follow a fiscal calendar by selecting the fiscal year start month within the report settings (Settings → Format). The change applies per report rather than requiring a global setting or custom formulas.</p>
<p>Learn more here: <a href="https://support.spiro.ai/article/648-spiro-release-january-2026">https://support.spiro.ai/article/648-spiro-release-january-2026</a></p>
";s:9:"text-flow";a:2:{i:0;s:237:"Reports can now be configured to follow a fiscal calendar by selecting the fiscal year start month within the report settings (Settings → Format). The change applies per report rather than requiring a global setting or custom formulas.";i:1;s:80:"Learn more here: https://support.spiro.ai/article/648-spiro-release-january-2026";}s:4:"meta";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}}s:7:"summary";s:187:"Reports can now be configured to follow a fiscal calendar by selecting the fiscal year start month within the report settings (Settings → Format). | Read fresh CRM news at WeekCRM";s:14:"comments-count";i:0;s:9:"tags-data";a:2:{s:5:"ctree";a:3:{i:0;a:3:{s:8:"visible?";b:1;s:4:"name";s:3:"CRM";s:4:"href";s:34:"https://weekcrm.com/blog/tags/crm/";}i:1;a:3:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:46:"https://weekcrm.com/blog/tags/product-updates/";}i:2;a:3:{s:8:"visible?";b:1;s:4:"name";s:5:"Spiro";s:4:"href";s:36:"https://weekcrm.com/blog/tags/spiro/";}}s:20:"all-resnames-uploads";a:0:{}}}