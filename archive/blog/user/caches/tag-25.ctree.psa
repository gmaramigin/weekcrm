a:3:{s:11:"notes_total";i:2;s:11:"notes_ctree";a:2:{i:0;a:32:{s:2:"id";i:9;s:5:"title";s:42:"Clay Launches Business Card Scanner on iOS";s:4:"href";s:70:"http://weekcrm.com/blog/all/clay-crm-business-card-scanner-ios-launch/";s:13:"href-original";s:70:"http://weekcrm.com/blog/all/clay-crm-business-card-scanner-ios-launch/";s:4:"time";a:2:{i:0;i:1747746579;i:1;a:2:{s:6:"offset";i:18000;s:6:"is_dst";b:0;}}s:13:"last-modified";a:2:{i:0;i:1747746555;i:1;a:2:{s:6:"offset";i:18000;s:6:"is_dst";b:0;}}s:4:"text";s:1030:"<p><a href="https://clay.earth/">Clay</a> just introduced a fast, accurate business card scanner inside its iOS app. Ideal for networking events, conferences, or cleaning up that drawer full of cards.</p>
<p>With just a tap, you can scan a card using your camera or upload a photo from your camera roll. Clay detects the card’s edges and extracts key info instantly: name, phone, email, address, even LinkedIn profiles.</p>
<p>But it doesn’t stop there. Every scan is automatically enriched with Clay’s profile enhancement features pulling in photos, education, work history, and social links. This turns plain contact info into fully built profiles.</p>
<p>You can immediately:</p>
<ul>
<li>Add notes</li>
<li>Set follow-up reminders</li>
<li>Organize contacts into groups</li>
</ul>
<p>There’s also an automatic mode for scanning multiple cards in a row, saving time without losing accuracy.</p>
<p>The new card scanner is available now on iOS just tap the + button and select the scanner icon.</p>
";s:11:"format-info";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}s:7:"summary";s:155:"Clay CRM adds a business card scanner to its iOS app. Scan, enrich, and organize contacts instantly with no manual entry — now available in one tap.";s:12:"snippet-text";s:155:"Clay CRM adds a business card scanner to its iOS app. Scan, enrich, and organize contacts instantly with no manual entry — now available in one tap.";s:6:"draft?";b:0;s:10:"scheduled?";b:0;s:7:"public?";b:1;s:7:"hidden?";b:0;s:8:"current?";b:0;s:10:"favourite?";b:0;s:6:"images";a:0:{}s:6:"thumbs";a:0:{}s:21:"source-main-image-url";s:0:"";s:9:"og-images";a:0:{}s:16:"og-images-thumbs";a:0:{}s:4:"tags";a:2:{i:0;a:4:{s:8:"visible?";b:1;s:4:"name";s:4:"clay";s:4:"href";s:35:"https://weekcrm.com/blog/tags/clay/";s:8:"current?";b:1;}i:1;a:4:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:46:"https://weekcrm.com/blog/tags/product-updates/";s:8:"current?";b:0;}}s:15:"sharing-buttons";b:0;s:7:"related";b:0;s:9:"read-href";s:75:"http://weekcrm.com/blog/all/clay-crm-business-card-scanner-ios-launch/read/";s:12:"preview-href";b:0;s:14:"comments-count";i:0;s:19:"comments-count-text";s:9:"0 comment";s:18:"new-comments-count";b:0;s:23:"new-comments-count-text";s:0:"";s:14:"comments-link?";b:1;s:13:"href-comments";s:79:"http://weekcrm.com/blog/all/clay-crm-business-card-scanner-ios-launch/#comments";}i:1;a:32:{s:2:"id";i:7;s:5:"title";s:55:"Clay Adds New Activity View + UX Fixes Across Platforms";s:4:"href";s:79:"http://weekcrm.com/blog/all/clay-crm-activity-view-update-and-fixes-april-2025/";s:13:"href-original";s:79:"http://weekcrm.com/blog/all/clay-crm-activity-view-update-and-fixes-april-2025/";s:4:"time";a:2:{i:0;i:1747057200;i:1;a:2:{s:6:"offset";i:18000;s:6:"is_dst";b:0;}}s:13:"last-modified";a:2:{i:0;i:1747057147;i:1;a:2:{s:6:"offset";i:18000;s:6:"is_dst";b:0;}}s:4:"text";s:1022:"<p><a href="https://clay.earth/">Clay</a> has introduced a new Activity view, now available in the top-right app menu across web, desktop, and iOS.</p>
<p>Activity shows:</p>
<ul>
<li>New contacts added to your workspace</li>
<li>Duplicate profiles ready for review</li>
<li>A log of recent Clay product updates — so you stay informed without leaving your workflow</li>
</ul>
<p>This makes it easier to track changes in your network and stay aware of what’s evolving inside Clay without checking release notes manually.</p>
<p>Additional updates in this release:</p>
<ul>
<li>Desktop UI cleanup: removed unnecessary padding from horizontal scrollbars</li>
<li>Mobile fixes for contact sources, message layout, and birthdate formatting</li>
<li>Firefox-specific improvements to sticky menu backgrounds</li>
<li>Account status alerts now appear in the main app menu, not the Home feed</li>
</ul>
<p>The update focuses on visibility, cleanup, and helping users catch what matters without noise.</p>
";s:11:"format-info";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}s:7:"summary";s:156:"Clay CRM now features an Activity view to track new contacts, review duplicates, and follow product updates. Plus UI fixes across web, desktop, and iOS.";s:12:"snippet-text";s:156:"Clay CRM now features an Activity view to track new contacts, review duplicates, and follow product updates. Plus UI fixes across web, desktop, and iOS.";s:6:"draft?";b:0;s:10:"scheduled?";b:0;s:7:"public?";b:1;s:7:"hidden?";b:0;s:8:"current?";b:0;s:10:"favourite?";b:0;s:6:"images";a:0:{}s:6:"thumbs";a:0:{}s:21:"source-main-image-url";s:0:"";s:9:"og-images";a:0:{}s:16:"og-images-thumbs";a:0:{}s:4:"tags";a:2:{i:0;a:4:{s:8:"visible?";b:1;s:4:"name";s:4:"clay";s:4:"href";s:35:"https://weekcrm.com/blog/tags/clay/";s:8:"current?";b:1;}i:1;a:4:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:46:"https://weekcrm.com/blog/tags/product-updates/";s:8:"current?";b:0;}}s:15:"sharing-buttons";b:0;s:7:"related";b:0;s:9:"read-href";s:84:"http://weekcrm.com/blog/all/clay-crm-activity-view-update-and-fixes-april-2025/read/";s:12:"preview-href";b:0;s:14:"comments-count";i:0;s:19:"comments-count-text";s:9:"0 comment";s:18:"new-comments-count";b:0;s:23:"new-comments-count-text";s:0:"";s:14:"comments-link?";b:1;s:13:"href-comments";s:88:"http://weekcrm.com/blog/all/clay-crm-activity-view-update-and-fixes-april-2025/#comments";}}s:11:"pages_ctree";a:5:{s:9:"timeline?";b:1;s:5:"count";i:1;s:4:"this";i:1;s:13:"earlier-title";s:7:"Earlier";s:11:"later-title";s:5:"Later";}}