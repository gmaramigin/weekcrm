a:5:{s:5:"title";s:76:"Scoro schedules subtasks rollout for February 2026, with new planning logic";s:16:"text-format-info";a:3:{s:10:"text-final";s:566:"<p>Scoro plans to introduce subtasks starting in February 2026 via a staged rollout. Alongside subtasks, Scoro will add work planning methods that control how budgeted hours and planned hours interact.</p>
<p>Rollout details:</p>
<p>Gradual release to groups of sites</p>
<p>Admin notification when available (in-app prompt)</p>
<p>No automatic workflow changes—existing setup remains until a team opts in</p>
<p>Learn more here: <a href="https://www.scoro.com/blog/scoro-version-update-26-1/">https://www.scoro.com/blog/scoro-version-update-26-1/</a></p>
";s:9:"text-flow";a:6:{i:0;s:198:"Scoro plans to introduce subtasks starting in February 2026 via a staged rollout. Alongside subtasks, Scoro will add work planning methods that control how budgeted hours and planned hours interact.";i:1;s:16:"Rollout details:";i:2;s:34:"Gradual release to groups of sites";i:3;s:49:"Admin notification when available (in-app prompt)";i:4;s:75:"No automatic workflow changes—existing setup remains until a team opts in";i:5;s:70:"Learn more here: https://www.scoro.com/blog/scoro-version-update-26-1/";}s:4:"meta";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}}s:7:"summary";s:109:"Scoro schedules subtasks rollout for February 2026, with new planning logic | Read fresh CRM news on WeekCRM";s:14:"comments-count";i:0;s:9:"tags-data";a:2:{s:5:"ctree";a:3:{i:0;a:3:{s:8:"visible?";b:1;s:4:"name";s:3:"CRM";s:4:"href";s:33:"http://weekcrm.com/blog/tags/crm/";}i:1;a:3:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:45:"http://weekcrm.com/blog/tags/product-updates/";}i:2;a:3:{s:8:"visible?";b:1;s:4:"name";s:5:"scoro";s:4:"href";s:35:"http://weekcrm.com/blog/tags/scoro/";}}s:20:"all-resnames-uploads";a:0:{}}}