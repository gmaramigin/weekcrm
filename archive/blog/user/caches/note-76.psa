a:5:{s:5:"title";s:42:"Spiro adds URL sharing for filtered views";s:16:"text-format-info";a:3:{s:10:"text-final";s:386:"<p>Users can now share a filtered view in Spiro by sending the page URL. When another user opens the link while logged into Spiro, they’ll see the same filtered dataset and can save the filter for ongoing use.</p>
<p>Learn more: <a href="https://support.spiro.ai/article/648-spiro-release-january-2026">https://support.spiro.ai/article/648-spiro-release-january-2026</a></p>
";s:9:"text-flow";a:2:{i:0;s:208:"Users can now share a filtered view in Spiro by sending the page URL. When another user opens the link while logged into Spiro, they’ll see the same filtered dataset and can save the filter for ongoing use.";i:1;s:75:"Learn more: https://support.spiro.ai/article/648-spiro-release-january-2026";}s:4:"meta";a:2:{s:14:"links-required";a:0:{}s:18:"resources-detected";a:0:{}}}s:7:"summary";s:76:"Spiro adds URL sharing for filtered views | Read fresh CRM news at WeekCRM";s:14:"comments-count";i:0;s:9:"tags-data";a:2:{s:5:"ctree";a:3:{i:0;a:3:{s:8:"visible?";b:1;s:4:"name";s:3:"CRM";s:4:"href";s:34:"https://weekcrm.com/blog/tags/crm/";}i:1;a:3:{s:8:"visible?";b:1;s:4:"name";s:15:"product updates";s:4:"href";s:46:"https://weekcrm.com/blog/tags/product-updates/";}i:2;a:3:{s:8:"visible?";b:1;s:4:"name";s:5:"Spiro";s:4:"href";s:36:"https://weekcrm.com/blog/tags/spiro/";}}s:20:"all-resnames-uploads";a:0:{}}}